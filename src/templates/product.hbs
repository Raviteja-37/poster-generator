<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=1080, height=1080" />
  <link
  rel='stylesheet'
  href='{{baseUrl}}/styles/{{template}}.css'
/>
</head>

<body>

  {{!--
    TEMPLATE: product — launches, feature drops, pricing posts

    Required:  headline (product name)
    Optional:  subtitle (tagline), badge{text,type},
               features[{title,description}]  (keep to 2-4 items)
               price{amount,period}
               stats[{value,label}]
               quote{text,author}, cta{title,url}, footer
               background, layout (showcase|spotlight), accentColor

    No hashtags/tags render in the image.
  --}}

  <div
    class="poster"
    data-layout="{{#if layout}}{{layout}}{{else}}showcase{{/if}}"
    style="background-image:url('{{baseUrl}}/assets/backgrounds/{{background}}'); --accent: {{#if accentColor}}{{accentColor}}{{else}}#5B8DEF{{/if}};"
  >
    <div class="overlay">
      <span class="trace trace-tl" aria-hidden="true"></span>
      <span class="trace trace-br" aria-hidden="true"></span>

      <header class="header">
        <img class="logo logo-left" src='{{baseUrl}}/assets/logos/silicofeller.png' alt="Silicofeller" />
        <img class="logo logo-right" src='{{baseUrl}}/assets/logos/nvidia.png' alt="NVIDIA" />
      </header>

      {{#if badge}}
        <div class="badge-row">
          <span class="badge" data-type="{{#if badge.type}}{{badge.type}}{{else}}primary{{/if}}">{{badge.text}}</span>
        </div>
      {{/if}}

      <main class="content">

        <div class="text-block">
          <h1 class="headline">{{headline}}</h1>
          {{#if subtitle}}<h2 class="subtitle">{{subtitle}}</h2>{{/if}}
          <div class="rule"><span class="rule-node"></span></div>
        </div>

        {{#if price}}
          <div class="price-row">
            <span class="price-amount">{{price.amount}}</span>
            {{#if price.period}}<span class="price-period">/ {{price.period}}</span>{{/if}}
          </div>
        {{/if}}

        {{#if features}}
          <div class="features">
            {{#each features}}
              <div class="feature">
                <span class="feature-mark"></span>
                <div class="feature-body">
                  <div class="feature-title">{{title}}</div>
                  {{#if description}}<div class="feature-desc">{{description}}</div>{{/if}}
                </div>
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if stats}}
          <div class="stats">
            {{#each stats}}
              <div class="card">
                <div class="number">{{value}}</div>
                <div class="label">{{label}}</div>
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if quote}}
          <div class="quote">
            <p class="quote-text">{{quote.text}}</p>
            {{#if quote.author}}<div class="quote-author">{{quote.author}}</div>{{/if}}
          </div>
        {{/if}}

        {{#if cta}}
          <a class="cta">{{cta.title}}</a>
        {{/if}}

      </main>

      <footer class="footer">
        <span class="footer-line"></span>
        <div class="footer-brand">
          <span>{{#if footer}}{{footer}}{{else}}SilicoFeller • Engineering the Future of Chips{{/if}}</span>
        </div>
      </footer>

    </div>
  </div>

  <script>
    (function () {
      var MIN_SCALE = 0.6;
      var MAX_SCALE = 1.3;
      var STEP = 0.03;
      var poster = document.querySelector(".poster");
      var content = document.querySelector(".content");

      function run() {
        if (!content || !poster) {
          document.body.setAttribute("data-fit-done", "true");
          return;
        }
        var scale = 1;
        function setScale(s) { poster.style.setProperty("--fit-scale", s.toFixed(3)); }
        function fits() { return content.scrollHeight <= content.clientHeight + 1; }

        setScale(scale);

        // too tall -> shrink until it fits (or hits the floor)
        var guard = 0;
        while (!fits() && scale > MIN_SCALE && guard < 30) {
          scale = Math.max(MIN_SCALE, scale - STEP);
          setScale(scale);
          guard++;
        }

        // room to spare -> grow to fill the canvas (or hits the ceiling)
        guard = 0;
        while (fits() && scale < MAX_SCALE && guard < 30) {
          var next = Math.min(MAX_SCALE, scale + STEP);
          setScale(next);
          if (fits()) {
            scale = next;
          } else {
            setScale(scale);
            break;
          }
          guard++;
        }

        document.body.setAttribute("data-fit-done", "true");
      }

      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(run).catch(run);
      } else {
        run();
      }
    })();
  </script>
</body>

</html>
