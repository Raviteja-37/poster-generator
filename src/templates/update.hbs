<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=1080, height=1080" />
  <link
  rel='stylesheet'
  href='{{baseUrl}}/styles/{{template}}.css'
/>
</head>

<body>

  {{!--
    TEMPLATE: update — product/release/company updates

    Required:  headline
    Optional:  subtitle, badge{text,type}, version (e.g. "v2.4.0"),
               changes[{type,text}]  -> type: new | improved | fixed
               stats[{value,label}]
               quote{text,author}, cta{title,url}, tags[], footer
               background, layout (changelog|highlight), accentColor
  --}}

  <div
    class="poster"
    data-layout="{{#if layout}}{{layout}}{{else}}changelog{{/if}}"
    style="background-image:url('{{baseUrl}}/assets/backgrounds/{{background}}'); --accent: {{#if accentColor}}{{accentColor}}{{else}}#5B8DEF{{/if}};"
  >
    <div class="overlay">
      <span class="trace trace-tl" aria-hidden="true"></span>
      <span class="trace trace-br" aria-hidden="true"></span>

      <header class="header">
        <img class="logo logo-left" src='{{baseUrl}}/assets/logos/silicofeller.png' alt="Silicofeller" />
        <img class="logo logo-right" src='{{baseUrl}}/assets/logos/nvidia.png' alt="NVIDIA" />
      </header>

      <div class="badge-row">
        {{#if badge}}
          <span class="badge" data-type="{{#if badge.type}}{{badge.type}}{{else}}primary{{/if}}">{{badge.text}}</span>
        {{/if}}
        {{#if version}}
          <span class="version-chip">{{version}}</span>
        {{/if}}
      </div>

      <main class="content">

        <div class="text-block">
          <h1 class="headline">{{headline}}</h1>
          {{#if subtitle}}<h2 class="subtitle">{{subtitle}}</h2>{{/if}}
          <div class="rule"><span class="rule-node"></span></div>
        </div>

        {{#if changes}}
          <div class="changelog">
            {{#each changes}}
              <div class="change-row" data-type="{{type}}">
                <span class="change-tag">{{type}}</span>
                <span class="change-text">{{text}}</span>
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if stats}}
          <div class="stats">
            {{#each stats}}
              <div class="card">
                <div class="number">{{value}}</div>
                <div class="label">{{label}}</div>
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{#if quote}}
          <div class="quote">
            <p class="quote-text">{{quote.text}}</p>
            {{#if quote.author}}<div class="quote-author">{{quote.author}}</div>{{/if}}
          </div>
        {{/if}}

        {{#if cta}}
          <a class="cta">{{cta.title}}</a>
        {{/if}}

      </main>

      <footer class="footer">
        <span class="footer-line"></span>
        <div class="tags-row">
          {{#each tags}}
            <span class="tag">{{this}}</span>
          {{else}}
            <span class="tag">#SilicoFeller</span>
          {{/each}}
        </div>
        <div class="footer-brand">
          <span>{{#if footer}}{{footer}}{{else}}SilicoFeller • Engineering the Future of Chips{{/if}}</span>
        </div>
      </footer>

    </div>
  </div>

</body>

</html>
